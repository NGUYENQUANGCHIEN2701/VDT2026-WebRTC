# Copy to .env and fill in real values. .env is gitignored — never commit it.
# Docker Compose loads this automatically and injects the vars into containers.

# --- PostgreSQL (consumed by the postgres service AND the backend) ---
POSTGRES_DB=vdt_webrtc
POSTGRES_USER=vdt
POSTGRES_PASSWORD=change-me-strong-password

# --- Backend datasource (built from the values above; host = compose service name) ---
DB_URL=jdbc:postgresql://postgres:5432/vdt_webrtc
DB_USERNAME=vdt
DB_PASSWORD=change-me-strong-password

# --- Auth ---
# Use a long random string (>= 32 chars). Generate e.g. `openssl rand -base64 48`.
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
