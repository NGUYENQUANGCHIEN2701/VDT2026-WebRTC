# Copy to .env and fill in real values. .env is gitignored — never commit it.
# Docker Compose loads this automatically and injects the vars into containers.

# --- PostgreSQL (consumed by the postgres service AND the backend) ---
POSTGRES_DB=vdt_webrtc
POSTGRES_USER=vdt
POSTGRES_PASSWORD=change-me-strong-password

# --- Backend datasource (built from the values above; host = compose service name) ---
DB_URL=jdbc:postgresql://postgres:5432/vdt_webrtc
DB_USERNAME=vdt
DB_PASSWORD=change-me-strong-password

# --- Auth ---
# Use a long random string (>= 32 chars). Generate e.g. `openssl rand -base64 48`.
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# --- TURN / NAT traversal (Phase 3) ---
# TURN_SECRET phải GIỐNG HỆT turn.secret của backend (coturn tự tính lại HMAC để xác thực).
# Tạo: openssl rand -hex 32
TURN_SECRET=change-me-shared-turn-secret
# IP LAN của máy demo (coturn external-ip + URL TURN cấp cho trình duyệt)
HOST_IP=192.168.1.100
# Host:port coturn mà /api/turn-credentials quảng bá
TURN_SERVER=192.168.1.100:3478

# --- Monitoring (Prometheus/Grafana) ---
# Grafana admin login — set a real value; blank/unset falls back to admin/admin, change for anything beyond local dev
GRAFANA_ADMIN_PASSWORD=
