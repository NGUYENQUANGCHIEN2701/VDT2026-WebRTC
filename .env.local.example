# Local dev credentials — copy to .env.local. Run: docker compose --env-file .env.local up --build
# All values below are dev-only placeholders. Never reuse these in production.

# --- PostgreSQL ---
POSTGRES_DB=vdt_webrtc
POSTGRES_USER=vdt_local
POSTGRES_PASSWORD=change-me-local-password

# --- JWT ---
JWT_SECRET=change-me-local-jwt-secret-min-32-chars-please-rotate

# --- Google Sign-In (leave blank to disable) ---
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# --- Password reset ---
# Local dev convenience: expose the raw reset token in the API response
# so you can test the flow without a real mailbox.
PASSWORD_RESET_EXPOSE_TOKEN=true

# --- Email delivery (leave blank to just log emails instead of sending) ---
EMAIL_USERNAME=
EMAIL_APP_PASSWORD=

# --- Frontend / CORS / WS origin whitelist ---
FRONTEND_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,https://localhost:5173

# --- Email auto-verify (comma-separated domains, leave blank to disable) ---
EMAIL_AUTO_VERIFY_DOMAINS=

# --- TURN / coturn ---
TURN_SECRET=change-me-local-turn-secret
TURN_SERVER=127.0.0.1:3478
HOST_IP=127.0.0.1

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=change-me-local-grafana-password

# --- Auth endpoint IP rate limiting (register / resend-otp / forgot-password) ---
RATE_LIMIT_OTP_WINDOW_SECONDS=900
RATE_LIMIT_OTP_MAX_REQUESTS=5
