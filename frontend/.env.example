# Copy sang .env. Khi chạy HTTP thường (1 máy, localhost) giữ nguyên giá trị dưới.
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws

# --- HTTPS/WSS (Phase 3, demo 2 thiết bị qua IP LAN) ---
# Khi phục vụ qua HTTPS (mkcert), tạo file .env.local (đã gitignore) ghi đè bằng IP LAN máy bạn:
#   VITE_API_URL=https://192.168.1.100:8080
#   VITE_WS_URL=wss://192.168.1.100:8080/ws
# (.env.example để mẫu localhost; .env.local giữ giá trị IP riêng của máy.)
