# Production credentials (AWS EC2) — copy to .env.prod. NEVER commit this file.
# Run: docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.prod.yml up -d --build
# All values below are placeholders — replace every one with real, strong secrets before deploying.

# --- PostgreSQL ---
POSTGRES_DB=vdt_webrtc
POSTGRES_USER=vdt_prod
POSTGRES_PASSWORD=<STRONG-RANDOM-DB-PASSWORD>

# --- JWT ---
JWT_SECRET=<STRONG-RANDOM-JWT-SECRET-MIN-64-CHARS>

# --- Google Sign-In (leave blank to disable) ---
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# --- Password reset ---
# MUST be false in production — true exposes the raw reset token in the API response (demo-only hack)
PASSWORD_RESET_EXPOSE_TOKEN=false

# --- Email delivery (leave blank to just log emails instead of sending) ---
EMAIL_USERNAME=
EMAIL_APP_PASSWORD=

# --- Frontend / CORS / WS origin whitelist ---
FRONTEND_URL=https://vdtcall.site
ALLOWED_ORIGINS=https://vdtcall.site

# --- Email auto-verify (comma-separated domains, leave blank to disable) ---
EMAIL_AUTO_VERIFY_DOMAINS=

# --- TURN / coturn ---
TURN_SECRET=<STRONG-RANDOM-TURN-SECRET>
TURN_SERVER=vdtcall.site:3478
HOST_IP=<EC2-public-IP>

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=<STRONG-RANDOM-GRAFANA-PASSWORD>

# --- Auth endpoint IP rate limiting (register / resend-otp / forgot-password) ---
RATE_LIMIT_OTP_WINDOW_SECONDS=900
RATE_LIMIT_OTP_MAX_REQUESTS=5
